{
  "$schema": "https://mintlify.com/docs.json",
  "name": "StatHub",
  "theme": "palm",
  "colors": {
    "primary": "#16A34A",
    "light": "#DCFCE7",
    "dark": "#14532D"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/codic-yeeshu/stathub"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/codic-yeeshu/stathub"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "deployment"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/real-time",
              "concepts/authentication",
              "concepts/data-model"
            ]
          },
          {
            "group": "Server",
            "pages": [
              "server/setup",
              "server/configuration",
              "server/database",
              "server/security"
            ]
          },
          {
            "group": "Client",
            "pages": [
              "client/setup",
              "client/features"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api/overview"]
          },
          {
            "group": "Authentication",
            "pages": [
              "api/auth/signup",
              "api/auth/login",
              "api/auth/google",
              "api/auth/forgot-password",
              "api/auth/reset-password"
            ]
          },
          {
            "group": "Matches",
            "pages": [
              "api/matches/list",
              "api/matches/create"
            ]
          },
          {
            "group": "Commentary",
            "pages": [
              "api/commentary/list",
              "api/commentary/create"
            ]
          },
          {
            "group": "WebSocket",
            "pages": [
              "api/websocket/overview",
              "api/websocket/events"
            ]
          }
        ]
      }
    ]
  }
}

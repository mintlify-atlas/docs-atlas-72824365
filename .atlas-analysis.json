  "keyFeatures": [
    "Real-time match score tracking via WebSockets",
    "Live text commentary for matches",
    "Match subscription system for targeted real-time updates",
    "JWT-based authentication with Google OAuth support",
    "Password reset via email (Resend)",
    "Arcjet security middleware for API and WebSocket protection",
    "PostgreSQL database with Drizzle ORM for type-safe queries",
    "React frontend with Tailwind CSS",
    "Docker support for both server and client deployment"
  ],
  "publicApiSurface": [
    "GET /matches — List matches with optional limit",
    "POST /matches — Create a new match",
    "GET /matches/:id/commentary — List commentary for a match",
    "POST /matches/:id/commentary — Add commentary to a match",
    "POST /api/auth/signup — Register a new user",
    "POST /api/auth/login — Login with email/password",
    "POST /api/auth/google — Login with Google OAuth",
    "POST /api/auth/forgot-password — Request password reset email",
    "POST /api/auth/reset-password — Reset password with token",
    "WS /ws — WebSocket endpoint for real-time events",
    "WS event: match_created — Broadcast when a match is created",
    "WS event: commentary — Broadcast to match subscribers when commentary is added",
    "WS message: subscribe — Subscribe to a match's real-time commentary",
    "WS message: unsubscribe — Unsubscribe from a match's real-time commentary"
  ]
}
